{
  "name": "web-documentation-to-markdown",
  "version": "1.0.0",
  "description": "Convert technical documentation to clean, LLM-friendly Markdown format",
  "keywords": [
    "apple",
    "converter",
    "developer-tools",
    "documentation",
    "markdown",
    "nextjs",
    "tailwindcss",
    "typescript",
    "web-scraping"
  ],
  "homepage": "https://llm.codes/",
  "bugs": {
    "url": "https://github.com/amantus-ai/llm-codes/issues"
  },
  "license": "MIT",
  "author": "Peter Steinberger",
  "repository": {
    "type": "git",
    "url": "https://github.com/amantus-ai/llm-codes.git"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm run format:check && oxlint --deny-warnings --allow eslint/no-useless-escape --allow jest/no-conditional-expect --allow jest/require-to-throw-message --allow unicorn/prefer-string-starts-ends-with --allow vitest/no-conditional-expect --allow vitest/require-mock-type-parameters --import-plugin --react-plugin --nextjs-plugin --vitest-plugin src",
    "test": "vitest",
    "test:run": "vitest run",
    "test:api": "vitest run src/app/api src/lib/__tests__/firecrawl.test.ts src/lib/__tests__/http2-client.test.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "verify": "pnpm run lint && pnpm run type-check && pnpm run test:run && pnpm run test:coverage && pnpm run build",
    "verify:firecrawl:live": "node scripts/verify-firecrawl.mjs",
    "verify:modes:live": "node scripts/verify-modes.mjs",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "lz-string": "^1.5.0",
    "next": "16.2.10",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "happy-dom": "^20.10.6",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
