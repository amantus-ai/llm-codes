{
  "name": "web-documentation-to-markdown",
  "version": "1.0.0",
  "description": "Convert technical documentation from 69+ major sites to clean, LLM-friendly Markdown format",
  "keywords": [
    "apple",
    "converter",
    "developer-tools",
    "documentation",
    "markdown",
    "nextjs",
    "tailwindcss",
    "typescript",
    "web-scraping"
  ],
  "homepage": "https://llm.codes/",
  "bugs": {
    "url": "https://github.com/amantusai/llm-tech/issues"
  },
  "license": "MIT",
  "author": "Peter Steinberger",
  "repository": {
    "type": "git",
    "url": "https://github.com/amantusai/llm-tech.git"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm run format:check && oxlint --deny-warnings --allow eslint/no-useless-escape --allow jest/no-conditional-expect --allow jest/require-to-throw-message --allow unicorn/prefer-string-starts-ends-with --allow vitest/no-conditional-expect --allow vitest/require-mock-type-parameters --import-plugin --react-plugin --nextjs-plugin --vitest-plugin src",
    "test": "vitest",
    "test:run": "vitest run",
    "test:api": "vitest run src/app/api src/lib/__tests__/firecrawl.test.ts src/lib/__tests__/http2-client.test.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "type-check": "tsgo --noEmit",
    "verify": "pnpm run lint && pnpm run type-check && pnpm run test:run && pnpm run test:coverage && pnpm run build",
    "verify:firecrawl:live": "node scripts/verify-firecrawl.mjs",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "lz-string": "^1.5.0",
    "next": "16.2.5",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "undici": "^8.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@typescript/native-preview": "7.0.0-dev.20260506.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "happy-dom": "^20.9.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
